# PostgreSQL (override to match docker-compose defaults in dev)
DATABASE_URL=postgresql://nutrideby:nutrideby_dev@localhost:5432/nutrideby

# Redis (Celery / filas — uso futuro)
REDIS_URL=redis://localhost:6379/0

# Datebox / CRM (preencher com URLs reais quando disponível)
CRM_BASE_URL=https://app.datebox.example
CRM_USERNAME=
CRM_PASSWORD=
# Login Playwright (opcional): seletores CSS reais do Datebox
CRM_LOGIN_USER_SELECTOR=
CRM_LOGIN_PASSWORD_SELECTOR=
CRM_LOGIN_SUBMIT_SELECTOR=

# DeepSeek (geração — uso futuro)
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com

# DigitalOcean GenAI — agente RAG (URL sem path, ex.: https://xxxx.agents.do-ai.run)
GENAI_AGENT_URL=
GENAI_AGENT_ACCESS_KEY=

# Playwright
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_STORAGE_STATE=
