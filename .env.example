# API leitura interna (Sprint 2) — header X-API-Key nos /v1/*; vazio = sem auth (só dev)
NUTRIDEBY_API_KEY=

# Opcional: POST JSON quando ``dietbox_sync --smoke`` receber HTTP 401 (ex. Slack incoming webhook)
NUTRIDEBY_SMOKE_ALERT_WEBHOOK_URL=

# Kiwify: URL no painel = https://<host>/hooks/kiwify/<este_valor> (mesmo string no path e aqui)
KIWIFY_WEBHOOK_PATH_SECRET=

# PostgreSQL (override to match docker-compose defaults in dev)
DATABASE_URL=postgresql://nutrideby:nutrideby_dev@localhost:5432/nutrideby

# Redis (Celery / filas — uso futuro)
REDIS_URL=redis://localhost:6379/0

# Datebox / CRM (preencher com URLs reais quando disponível)
CRM_BASE_URL=https://app.datebox.example
CRM_USERNAME=
CRM_PASSWORD=
# Login Playwright (opcional): seletores CSS reais do Datebox
CRM_LOGIN_USER_SELECTOR=
CRM_LOGIN_PASSWORD_SELECTOR=
CRM_LOGIN_SUBMIT_SELECTOR=

# DeepSeek (geração — uso futuro)
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com

# DigitalOcean GenAI — agente RAG (URL sem path, ex.: https://xxxx.agents.do-ai.run)
GENAI_AGENT_URL=
GENAI_AGENT_ACCESS_KEY=

# OpenSearch — telemetria GenAI+RAG (cluster genai-estrela-do-mar / TOR1; índice configurável)
# Ex.: OPENSEARCH_URL=https://<host>:<porta>  OU  OPENSEARCH_HOSTS=host:443 (vírgula para vários)
OPENSEARCH_URL=
OPENSEARCH_HOSTS=
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX=nutrideby-genai-telemetry
OPENSEARCH_USE_SSL=true
OPENSEARCH_VERIFY_SSL=true
# Rótulos gravados em cada documento de telemetria (opcional)
OPENSEARCH_CLUSTER_LABEL=genai-estrela-do-mar
OPENSEARCH_REGION_LABEL=TOR1

# DigitalOcean Spaces — data lake (JSON de análise rag_demo; Postgres só guarda URL — migração 005)
SPACES_ACCESS_KEY_ID=
SPACES_SECRET_ACCESS_KEY=
SPACES_BUCKET=nutridebv2
SPACES_REGION=lon1
SPACES_ENDPOINT=https://lon1.digitaloceanspaces.com

# OpenAI-compatible embeddings (chunk + retrieve); ver docs/decisao-embeddings-vector-store.md
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Playwright
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_STORAGE_STATE=

# Dietbox — variáveis agrupadas em: env/API_JSON_V2/template.env (copiar para este .env)
DIETBOX_API_BASE=https://api.dietbox.me
DIETBOX_BEARER_TOKEN=
DIETBOX_WEB_BASE=https://dietbox.me
DIETBOX_WEB_LOCALE=pt-BR
