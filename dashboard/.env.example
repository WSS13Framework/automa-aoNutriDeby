# ── Dashboard NutriDeby ──────────────────────────────────────
# Copie para .env e preencha com os valores do seu servidor.

# URL da API NutriDeby (FastAPI). Dentro do Docker Compose: http://api:8080
NUTRIDEBY_API_URL=http://api:8080

# Chave de API (mesma NUTRIDEBY_API_KEY do .env raiz)
NUTRIDEBY_API_KEY=

# NextAuth — gere com: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Credenciais do admin (hash bcrypt gerado no deploy)
ADMIN_EMAIL=admin@nutrideby.com.br
ADMIN_PASSWORD_HASH=
