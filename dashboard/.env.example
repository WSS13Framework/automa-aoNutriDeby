# ============================================================
# NutriDeby Dashboard — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o .env com credenciais reais.
# ============================================================

# --- Banco de dados ---
DATABASE_URL=postgresql://nutrideby:nutrideby_secret@postgres:5432/nutrideby
POSTGRES_PASSWORD=nutrideby_secret

# --- LLM Provider ---
# Opções: deepseek | groq
LLM_PROVIDER=deepseek

# DeepSeek (ativo por padrão)
DEEPSEEK_API_KEY=

# Groq (inativo — trocar LLM_PROVIDER=groq para ativar)
GROQ_API_KEY=

# --- Autenticação ---
JWT_SECRET=troque-por-um-segredo-forte-de-pelo-menos-32-chars

# --- WhatsApp (Evolution API) ---
EVOLUTION_API_URL=
EVOLUTION_API_KEY=

# --- Ambiente ---
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
