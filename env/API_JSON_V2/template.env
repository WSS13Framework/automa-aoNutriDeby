# =============================================================================
# Dietbox — API JSON v2 (api.dietbox.me) + site (MVC, mesmo Bearer)
# Copia estas linhas para o .env na raiz do projecto e preenche os valores.
# Não commits este ficheiro com segredos (usa só placeholders aqui no repo).
# =============================================================================

# --- Obrigatório para workers dietbox_sync ---
# Valor do JWT *sem* o prefixo "Bearer " (copiar do DevTools → Network → api.dietbox.me).
DIETBOX_BEARER_TOKEN=

# Base da API (normalmente não mudar)
DIETBOX_API_BASE=https://api.dietbox.me

# --- Site dietbox.me (fórmulas tipo SituacaoIMC, Feed/List) — mesmo DIETBOX_BEARER_TOKEN ---
DIETBOX_WEB_BASE=https://dietbox.me
DIETBOX_WEB_LOCALE=pt-BR
